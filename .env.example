# ==============================================================================
# DLE-Pifagor environment example
# Общий .env.example для backend, frontend, docker-compose и infra
# ==============================================================================


# ==============================================================================
# Project
# ==============================================================================

PROJECT_NAME=DLE-Pifagor
COMPOSE_PROJECT_NAME=dle_pifagor

ENVIRONMENT=local


# ==============================================================================
# Backend / Django
# ==============================================================================

DJANGO_SETTINGS_MODULE=config.settings.local

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

DJANGO_TIME_ZONE=Europe/Moscow
DJANGO_LANGUAGE_CODE=ru-ru

DJANGO_PASSWORD_MIN_LENGTH=8

PIFAGOR_PROJECT_NAME=ЦОС «Пифагор»
PIFAGOR_API_PREFIX=/api/v1
PIFAGOR_ACCOUNT_DELETION_GRACE_DAYS=7


# ==============================================================================
# Backend / Database
# ==============================================================================

# Для локальной SQLite-разработки:
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3
DJANGO_DB_USER=
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=
DJANGO_DB_PORT=

# Для PostgreSQL через docker-compose можно использовать так:
POSTGRES_DB=pifagor
POSTGRES_USER=pifagor
POSTGRES_PASSWORD=pifagor
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Если backend будет читать PostgreSQL напрямую:
# DJANGO_DB_ENGINE=django.db.backends.postgresql
# DJANGO_DB_NAME=pifagor
# DJANGO_DB_USER=pifagor
# DJANGO_DB_PASSWORD=pifagor
# DJANGO_DB_HOST=postgres
# DJANGO_DB_PORT=5432


# ==============================================================================
# Backend / CORS and CSRF
# ==============================================================================

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# ==============================================================================
# Backend / JWT
# ==============================================================================

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=10
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

JWT_REFRESH_COOKIE_NAME=pifagor_refresh
JWT_REFRESH_COOKIE_SECURE=false
JWT_REFRESH_COOKIE_SAMESITE=Lax
JWT_REFRESH_COOKIE_PATH=/api/v1/auth/


# ==============================================================================
# Backend / Email
# ==============================================================================

DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@pifagor.local

# Production SMTP example:
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_EMAIL_HOST=smtp.example.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_HOST_USER=
# DJANGO_EMAIL_HOST_PASSWORD=
# DJANGO_EMAIL_USE_TLS=true
# DJANGO_DEFAULT_FROM_EMAIL=noreply@example.com


# ==============================================================================
# Backend / Redis and Celery
# ==============================================================================

REDIS_HOST=redis
REDIS_PORT=6379

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_TIME_LIMIT=1800


# ==============================================================================
# Backend / Security
# ==============================================================================

SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

SECURE_SSL_REDIRECT=false
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false


# ==============================================================================
# Backend / Logging
# ==============================================================================

DJANGO_LOG_LEVEL=INFO


# ==============================================================================
# Frontend / Vite
# ==============================================================================

VITE_APP_NAME=Пифагор
VITE_APP_ENV=local

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_BACKEND_ORIGIN=http://localhost:8000

VITE_ENABLE_MOCKS=false
VITE_ENABLE_DEVTOOLS=true


# ==============================================================================
# Docker ports
# ==============================================================================

BACKEND_PORT=8000
FRONTEND_PORT=5173
POSTGRES_PORT_EXTERNAL=5432
REDIS_PORT_EXTERNAL=6379
NGINX_PORT=80
NGINX_SSL_PORT=443